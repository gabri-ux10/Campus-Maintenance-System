# Database (MySQL)
DB_URL=jdbc:mysql://localhost:3306/Campus_Fix?allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=change-me

# Security
JWT_SECRET=replace-with-a-strong-secret-at-least-32-characters
JWT_EXPIRATION_MS=900000

# Frontend + CORS
FRONTEND_BASE_URL=http://localhost:5173
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Admin bootstrap (dev/local)
APP_SEED_BOOTSTRAP_ADMIN=true
APP_SEED_DEMO_DATA=true
APP_ADMIN_USERNAME=admin
APP_ADMIN_EMAIL=admin@campus.local
APP_ADMIN_FULL_NAME=Campus Admin
APP_ADMIN_PASSWORD=admin@123
APP_SEED_ADMIN_SYNC_EXISTING=true

# Email (keep disabled until SMTP is configured)
APP_EMAIL_ENABLED=false
APP_EMAIL_FROM=no-reply@campusfix.local
APP_EMAIL_SUPPORT_INBOX=support@campusfix.local
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Optional auth tuning
APP_AUTH_VERIFICATION_CODE_TTL_MINUTES=15
APP_AUTH_VERIFICATION_CODE_MAX_ATTEMPTS=5
APP_AUTH_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
APP_AUTH_MFA_CODE_TTL_MINUTES=10
APP_AUTH_MFA_CODE_MAX_ATTEMPTS=5
APP_AUTH_MFA_RESEND_COOLDOWN_SECONDS=45
APP_AUTH_MFA_REQUIRED_ROLES=
