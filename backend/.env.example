# Database (MySQL)
DB_URL=jdbc:mysql://localhost:3306/Campus_Fix?allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=change-me
SPRING_PROFILES_ACTIVE=dev
JPA_DDL_AUTO=update

# JWT
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRATION_MS=86400000

# Frontend links used in welcome/reset emails
FRONTEND_BASE_URL=http://localhost:5173
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Admin bootstrap account (created if no ADMIN exists)
APP_ADMIN_USERNAME=admin
APP_ADMIN_EMAIL=admin@campus.local
APP_ADMIN_FULL_NAME=Campus Admin
APP_ADMIN_PASSWORD=ChangeThisAdminPassword123!

# Demo data (disable for real environments)
APP_SEED_DEMO_DATA=false
APP_SEED_DEMO_PASSWORD=password
APP_AUTH_VERIFICATION_CODE_TTL_MINUTES=15
APP_AUTH_RESET_TOKEN_TTL_MINUTES=60
APP_AUTH_VERIFICATION_CODE_MAX_ATTEMPTS=5
APP_AUTH_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
APP_AUTH_RESET_REQUEST_COOLDOWN_SECONDS=60
APP_AUTH_PUBLIC_REQUEST_MIN_DELAY_MS=350
APP_AUTH_TOKEN_CLEANUP_CRON=0 15 * * * *
APP_AUTH_USED_TOKEN_RETENTION_HOURS=24

# Email / SMTP
# Recommended production setup: verify a custom sender domain in Resend and
# send from a domain-controlled address such as no-reply@mail.example.com.
APP_EMAIL_ENABLED=false
APP_EMAIL_FROM=no-reply@mail.example.com
APP_EMAIL_SUPPORT_INBOX=support@example.com
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=re_xxxxxxxxx
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=true

# Optional local/dev Gmail fallback
# APP_EMAIL_FROM=campusfixsystems@gmail.com
# APP_EMAIL_SUPPORT_INBOX=campusfixsystems@gmail.com
# MAIL_HOST=smtp.gmail.com
# MAIL_USERNAME=campusfixsystems@gmail.com
# MAIL_PASSWORD=your-gmail-app-password

# Optional when running with MySQL
H2_CONSOLE_ENABLED=false

# Upload storage
APP_UPLOAD_DIR=uploads
APP_UPLOAD_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp
APP_UPLOAD_MAX_FILE_SIZE_BYTES=5242880

# Optional native optimization module
APP_NATIVE_ENABLED=false
APP_NATIVE_STRICT=false
APP_NATIVE_LIBRARY_NAME=campusfix_native
APP_NATIVE_IMAGE_MIN_SAVINGS_PERCENT=5
APP_NATIVE_IMAGE_JPEG_QUALITY=85
APP_NATIVE_IMAGE_WEBP_QUALITY=85
